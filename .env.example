DATABASE_URL="postgresql://iconforge:iconforge_dev@localhost:5433/iconforge"

# ─── AI Providers ────────────────────────────────────────────────────────
# Set at least one to enable AI generation. The active provider is
# configured in src/lib/ai-providers.ts (ACTIVE_PROVIDER). If the active
# provider isn't configured or errors out, the server automatically falls
# back to other configured providers. Optional *_MODEL overrides pin a
# specific model.

