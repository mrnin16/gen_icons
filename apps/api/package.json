{
  "name": "@iconforge/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p ${PORT:-3001}",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:defaults": "tsx prisma/seed-defaults.ts",
    "db:seed:animated": "tsx prisma/seed-animated.ts",
    "db:seed:admin": "tsx prisma/seed-admin.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:deploy": "prisma migrate deploy && tsx prisma/seed-defaults.ts",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.29.1",
    "@anthropic-ai/sdk": "^0.91.1",
    "@google/generative-ai": "^0.24.1",
    "@iconforge/shared": "*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@resvg/resvg-js": "^2.6.2",
    "bcryptjs": "^3.0.3",
    "gif-encoder-2": "^1.0.5",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "lucide-static": "^1.12.0",
    "next": "16.2.4",
    "openai": "^6.35.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tar-stream": "^3.1.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/tar-stream": "^3.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
