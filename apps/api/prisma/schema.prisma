generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Icon {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  svgContent    String   @db.Text
  category      String
  style         String
  tags          String[]
  isAiGenerated Boolean  @default(false)
  isPublic      Boolean  @default(false)
  iconType      String   @default("static")
  animationData String?  @db.Text
  prompt        String?
  downloads     Int      @default(0)
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([category])
  @@index([style])
  @@index([iconType])
  @@index([isPublic])
  @@index([tags], type: Gin)
  @@index([name])
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String
  role          Role           @default(USER)
  icons         Icon[]
  uiGenerations UiGeneration[]
  createdAt     DateTime       @default(now())
}

model UiGeneration {
  id           String   @id @default(cuid())
  userId       String
  title        String
  prompt       String   @db.Text
  jsx          String   @db.Text
  html         String   @db.Text
  mode         String
  isRefine     Boolean  @default(false)
  provider     String
  model        String
  // Poster-specific (null for page/slides):
  aspectRatio  String?
  brandColor   String?
  logoUrl      String?  @db.Text
  productUrl   String?  @db.Text
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}
