# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (workspace root + per-app)
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build outputs (in any workspace)
.next/
out/

# testing
coverage/

# production
build/

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example tracked, never commit real secrets
.env
.env.local
.env.*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
