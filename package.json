{
  "name": "icon-forge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev:api": "npm run dev -w @iconforge/api",
    "dev:web": "npm run dev -w @iconforge/web",
    "build:api": "npm run build -w @iconforge/api",
    "build:web": "npm run build -w @iconforge/web"
  }
}
